# =============================================================================
# Delectable Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Django Backend
# -----------------------------------------------------------------------------
# SECURITY: Generate a new secret key for production!
# Use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_NEW_SECRET_KEY
DJANGO_SETTINGS_MODULE=config.settings.development
# SECURITY WARNING: Never set DEBUG=True in production!
DEBUG=False

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=delectable
POSTGRES_USER=delectable
POSTGRES_PASSWORD=your-database-password
DATABASE_URL=postgres://delectable:your-database-password@localhost:5432/delectable

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Next.js Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# -----------------------------------------------------------------------------
# Google Maps API
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# -----------------------------------------------------------------------------
# AWS (for production)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# -----------------------------------------------------------------------------
# Email (for production)
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@delectable.app

# -----------------------------------------------------------------------------
# Sentry (optional, for error tracking)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Docker-specific (used by docker-compose)
# -----------------------------------------------------------------------------
# These are read by docker-compose.yml
# POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD are also used above
